<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/charmModeBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone">

        <View
            android:id="@+id/charmLeftPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#FF2F5A" />

        <View
            android:id="@+id/charmDivider"
            android:layout_width="24dp"
            android:layout_height="match_parent"
            android:background="#000000" />

        <View
            android:id="@+id/charmRightPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#7A2EFF" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/previewContainer"
        android:layout_width="180dp"
        android:layout_height="240dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="28dp"
        android:background="#66000000"
        android:padding="2dp">

        <SurfaceView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <Button
            android:id="@+id/resizePreviewButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:background="#88000000"
            android:text="↔"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </FrameLayout>

    <ImageButton
        android:id="@+id/infoButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="#66000000"
        android:contentDescription="@string/info_button_desc"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_info_details"
        android:tint="#FFFFFF" />

    <LinearLayout
        android:id="@+id/controlsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:layout_marginBottom="124dp"
        android:background="#66000000"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/helpText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/help_text_default"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/charm_mode_label"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Switch
                android:id="@+id/neonModeSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:id="@+id/charmDividerLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/charm_divider_label"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:visibility="gone" />

        <SeekBar
            android:id="@+id/charmDividerSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="30"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/intensity_label"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <SeekBar
            android:id="@+id/intensitySlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="80" />

        <TextView
            android:id="@+id/intensityValueText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/hue_label"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <SeekBar
            android:id="@+id/hueSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/hue_left_label"
                android:textColor="#D6EEFF"
                android:textSize="12sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="@string/hue_right_label"
                android:textColor="#FFD6D6"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/hueValueText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:background="#66000000"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="10dp">

        <Button
            android:id="@+id/captureButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/capture_button"
            android:textSize="18sp" />

        <Button
            android:id="@+id/openGalleryButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:enabled="false"
            android:text="@string/open_gallery"
            android:textSize="14sp" />

        <Button
            android:id="@+id/toggleSettingsButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:text="@string/show_settings"
            android:textSize="14sp" />
    </LinearLayout>

</FrameLayout>
